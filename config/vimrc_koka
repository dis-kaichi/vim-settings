""" 共通設定読み込み
let language = 'koka'
let s:common_vimrc = expand('~/my/config/vimrc_common')
if filereadable(s:common_vimrc)
  execute 'source ' . s:common_vimrc
endif

" 実行コマンド
nnoremap [Exec] <Nop>
nmap <C-t> [Exec]
map <silent> [Exec]p :!koka -e % -o %:r; chmod +x %:r<CR>

" ----------------------------------------
"  filetypeの設定
" ----------------------------------------
au BufRead,BufNewFile *.{kk} set filetype=koka

